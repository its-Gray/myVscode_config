{
  // ─────────────────────────────────────────────
  //  EDITOR — FONTS
  //  Fira Code — ligature-rich, clean, great for JS & Rust
  //  Install: https://github.com/tonsky/FiraCode/releases
  // ─────────────────────────────────────────────
  "editor.fontFamily": "'Fira Code', monospace",
  "editor.fontSize": 15,
  "editor.lineHeight": 1.7,
  "editor.fontWeight": "400",
  "editor.fontLigatures": true,
  "editor.letterSpacing": 0.3,

  // ─────────────────────────────────────────────
  //  EDITOR — GENERAL FEEL
  // ─────────────────────────────────────────────
  "editor.tabSize": 2,
  "editor.insertSpaces": true,
  "editor.wordWrap": "off",
  "editor.cursorStyle": "line",
  "editor.cursorBlinking": "smooth",
  "editor.cursorSmoothCaretAnimation": "on",
  "editor.smoothScrolling": true,
  "editor.renderWhitespace": "boundary",
  "editor.renderLineHighlight": "all",
  "editor.rulers": [80, 100],
  "editor.minimap.enabled": true,
  "editor.minimap.renderCharacters": false,
  "editor.minimap.maxColumn": 80,
  "editor.bracketPairColorization.enabled": true,
  "editor.guides.bracketPairs": "active",
  "editor.inlayHints.enabled": "onUnlessPressed",
  "editor.suggest.preview": true,
  "editor.acceptSuggestionOnCommitCharacter": true,
  "editor.quickSuggestionsDelay": 50,
  "editor.parameterHints.enabled": true,
  "editor.hover.enabled": "on",
  "editor.occurrencesHighlight": "singleFile",

  // ─────────────────────────────────────────────
  //  SAVE BEHAVIOUR — NO AUTOSAVE, FORMAT ON SAVE
  // ─────────────────────────────────────────────
  "files.autoSave": "off",
  "editor.formatOnSave": true,
  "editor.formatOnPaste": false,
  "editor.formatOnType": false,
  "editor.codeActionsOnSave": {
    "source.fixAll": "explicit",
    "source.fixAll.eslint": "explicit",
    "source.organizeImports": "explicit",
  },
  "workbench.preferredDarkColorTheme": "Shades of Purple",

  // ─────────────────────────────────────────────
  //  ICONS — Material Icon Theme
  //  Install: pkief.material-icon-theme
  // ─────────────────────────────────────────────
  "workbench.iconTheme": "material-icon-theme",
  "material-icon-theme.activeIconPack": "react",
  "material-icon-theme.folders.theme": "specific",
  "material-icon-theme.folders.color": "#a163f1",
  "material-icon-theme.opacity": 1,
  "material-icon-theme.saturation": 1,

  // ─────────────────────────────────────────────
  //  TERMINAL
  // ─────────────────────────────────────────────
  "terminal.integrated.fontFamily": "'Fira Code', monospace",
  "terminal.integrated.fontSize": 14,
  "terminal.integrated.lineHeight": 1.4,
  "terminal.integrated.cursorStyle": "line",
  "terminal.integrated.cursorBlinking": true,
  "terminal.integrated.smoothScrolling": true,
  "terminal.integrated.defaultProfile.windows": "PowerShell",
  "terminal.integrated.defaultProfile.linux": "zsh",
  "terminal.integrated.defaultProfile.osx": "zsh",

  // ─────────────────────────────────────────────
  //  WORKBENCH
  // ─────────────────────────────────────────────
  "workbench.startupEditor": "none",
  "workbench.editor.enablePreview": false,
  "workbench.editor.showTabs": "multiple",
  "workbench.tree.indent": 16,
  "workbench.tree.renderIndentGuides": "always",
  "workbench.sideBar.location": "left",
  "workbench.statusBar.visible": true,

  // ─────────────────────────────────────────────
  //  JAVASCRIPT / TYPESCRIPT  (MERN stack)
  // ─────────────────────────────────────────────
  "[javascript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.tabSize": 2,
    "editor.formatOnSave": true,
  },
  "[javascriptreact]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.tabSize": 2,
    "editor.formatOnSave": true,
  },
  "[typescript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.tabSize": 2,
    "editor.formatOnSave": true,
  },
  "[typescriptreact]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.tabSize": 2,
    "editor.formatOnSave": true,
  },
  "[json]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.formatOnSave": true,
  },
  "[jsonc]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.formatOnSave": true,
  },
  "[html]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.formatOnSave": true,
  },
  "[css]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.formatOnSave": true,
  },
  "[markdown]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.wordWrap": "on",
    "editor.formatOnSave": false,
  },
  "javascript.updateImportsOnFileMove.enabled": "always",
  "typescript.updateImportsOnFileMove.enabled": "always",
  "javascript.inlayHints.parameterNames.enabled": "literals",
  "typescript.inlayHints.parameterNames.enabled": "literals",
  "typescript.inlayHints.functionLikeReturnTypes.enabled": true,
  "javascript.suggest.autoImports": true,
  "typescript.suggest.autoImports": true,

  // ─────────────────────────────────────────────
  //  REACT — Emmet in JSX files
  // ─────────────────────────────────────────────
  "emmet.includeLanguages": {
    "javascript": "javascriptreact",
    "typescript": "typescriptreact",
  },
  "emmet.triggerExpansionOnTab": true,

  // ─────────────────────────────────────────────
  //  NODE / EXPRESS
  // ─────────────────────────────────────────────
  "npm.autoDetect": "on",
  "npm.runSilent": false,

  // ─────────────────────────────────────────────
  //  RUST
  //  Requires: rust-lang.rust-analyzer
  // ─────────────────────────────────────────────
  "[rust]": {
    "editor.defaultFormatter": "rust-lang.rust-analyzer",
    "editor.tabSize": 4,
    "editor.formatOnSave": true,
  },
  "rust-analyzer.checkOnSave": true,
  "rust-analyzer.check.command": "clippy",
  "rust-analyzer.inlayHints.typeHints.enable": true,
  "rust-analyzer.inlayHints.parameterHints.enable": true,
  "rust-analyzer.inlayHints.chainingHints.enable": true,
  "rust-analyzer.inlayHints.closureReturnTypeHints.enable": "with_block",
  "rust-analyzer.lens.enable": true,
  "rust-analyzer.lens.run.enable": true,
  "rust-analyzer.lens.debug.enable": true,
  "rust-analyzer.cargo.features": "all",
  "rust-analyzer.procMacro.enable": true,
  "rust-analyzer.hover.actions.enable": true,
  "rust-analyzer.completion.autoimport.enable": true,

  // ─────────────────────────────────────────────
  //  GIT
  // ─────────────────────────────────────────────
  "git.autofetch": true,
  "git.confirmSync": false,
  "git.enableSmartCommit": true,
  "git.decorations.enabled": true,
  "scm.diffDecorations": "all",
  "gitlens.hovers.currentLine.over": "line",
  "gitlens.currentLine.enabled": true,

  // ─────────────────────────────────────────────
  //  EXPLORER & FILES
  // ─────────────────────────────────────────────
  "explorer.confirmDelete": false,
  "explorer.confirmDragAndDrop": false,
  "explorer.compactFolders": false,
  "files.trimTrailingWhitespace": true,
  "files.trimFinalNewlines": true,
  "files.insertFinalNewline": true,
  "files.exclude": {
    "**/.git": true,
    "**/node_modules": true,
    "**/target": true,
    "**/.DS_Store": true,
    "**/.next": true,
    "**/dist": true,
    "**/build": true,
  },
  "search.exclude": {
    "**/node_modules": true,
    "**/target": true,
    "**/dist": true,
    "**/build": true,
    "**/.next": true,
    "**/.git": true,
    "**/coverage": true,
  },

  // ─────────────────────────────────────────────
  //  PRETTIER
  //  Install: esbenp.prettier-vscode
  // ─────────────────────────────────────────────
  "prettier.semi": true,
  "prettier.singleQuote": true,
  "prettier.trailingComma": "es5",
  "prettier.printWidth": 100,
  "prettier.arrowParens": "avoid",
  "prettier.tabWidth": 2,
  "prettier.bracketSpacing": true,
  "prettier.jsxSingleQuote": false,

  // ─────────────────────────────────────────────
  //  ESLINT
  //  Install: dbaeumer.vscode-eslint
  // ─────────────────────────────────────────────
  "eslint.enable": true,
  "eslint.validate": ["javascript", "javascriptreact", "typescript", "typescriptreact"],
  "eslint.workingDirectories": [{ "mode": "auto" }],

  // ─────────────────────────────────────────────
  //  MONGODB (for MERN)
  //  Install: mongodb.mongodb-vscode
  // ─────────────────────────────────────────────
  "mdb.sendTelemetry": false,

  // ─────────────────────────────────────────────
  //  REST CLIENT — test Express APIs without Postman
  //  Install: humao.rest-client
  // ─────────────────────────────────────────────
  "rest-client.environmentVariables": {
    "$shared": {
      "baseUrl": "http://localhost:5000",
    },
  },

  // ─────────────────────────────────────────────
  //  MISC QUALITY-OF-LIFE
  // ─────────────────────────────────────────────
  "editor.stickyScroll.enabled": true,
  "editor.linkedEditing": true,
  "editor.multiCursorModifier": "alt",
  "editor.snippetSuggestions": "top",
  "breadcrumbs.enabled": true,
  "problems.showCurrentInStatus": true,
  "security.workspace.trust.untrustedFiles": "open",
  "telemetry.telemetryLevel": "off",
  "workbench.settings.applyToAllProfiles": [
  
  ],
  "workbench.colorTheme": "Fluent OLED",
  "workbench.productIconTheme": "fluent-icons",
}
